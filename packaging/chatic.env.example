# ============================================================
# Chatic — arquivo de configuração (.env)
# ============================================================
# Dica: você NÃO precisa colocar chaves de API aqui. O jeito recomendado é
# configurá-las pelo painel web (/admin), que as guarda cifradas em repouso.

# Porta do painel web/admin (padrão 3030)
PORT=3030

# Ambiente: production | development
ENV=production

# Provedor principal de LLM: gemini | openai | claude | ollama
PRIMARY_LLM_PROVIDER=gemini

# (Opcional) Chave de API via .env — prefira o painel web.
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# CLAUDE_API_KEY=

# Caminho do banco SQLite (relativo ao diretório de trabalho do serviço)
DATABASE_PATH=storage/tutor.db

# Número do administrador no WhatsApp — usado APENAS no primeiro boot para semear o
# admin. É dado pessoal: depois vive no banco e o bot não o reescreve aqui.
# Só dígitos, com DDI/DDD. Ex.: 5511999999999
INITIAL_ADMIN_NUMBER=

# (Opcional) Parear por código de telefone em vez de QR. Deixe vazio para usar QR.
# PAIR_CODE_PHONE=

# (Opcional) Modo multi-conta: cada pessoa da casa conecta o próprio WhatsApp e
# conversa com o tutor por self-chat (prefixo !), sem whitelist nem admin.
# true = habilita parear novas contas pessoais pelo painel. Padrão: false.
MULTI_ACCOUNT_ENABLED=false
